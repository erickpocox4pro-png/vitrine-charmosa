# SPA fallback — todas as rotas não-arquivo vão para index.html
# Sem wrapper <IfModule> porque LiteSpeed (Hostinger) não registra como mod_rewrite.c
Options -MultiViews
RewriteEngine On
RewriteBase /

# === REDIRECTS 301 (SEO — URLs antigas) ===
# URL antiga com query param ?categoria= → formato novo /categoria/
RewriteCond %{QUERY_STRING} ^categoria=Conjuntos$ [NC]
RewriteRule ^$ /categoria/conjuntos? [R=301,L]
RewriteCond %{QUERY_STRING} ^categoria=([^&]+)$ [NC]
RewriteRule ^$ /categoria/%1? [R=301,L,NE]

# Slugs deletados/migrados — redirecionam pra produto vivo
RewriteRule ^produto/macaquinho-brenda-1/?$ /produto/macaquinho-brenda [R=301,L]
RewriteRule ^produto/short-jeans-e3b2/?$ /produto/short-jeans-feminino [R=301,L]
# Short Jeans duplicados desativados → produto canônico
RewriteRule ^produto/short-jeans-(k2c4|p1l3|r5l7|thjk)/?$ /produto/short-jeans-feminino [R=301,L]

# Trailing slash → sem barra (canonical único)
RewriteCond %{REQUEST_URI} ^/(produto|categoria)/[^/]+/$
RewriteRule ^(.*)/$ /$1 [R=301,L]

# Não reescrever para arquivos ou diretórios reais
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Qualquer outra rota vai para index.html (SPA do React Router trata)
RewriteRule ^ index.html [L]

# Cache longo para assets com hash (Vite)
<FilesMatch "\.(js|css|woff2?|ttf|png|jpg|jpeg|gif|webp|svg|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# HTML nunca em cache
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
